# Optional native integrations. The app runs without these using transparent local fallbacks.

# Databricks / OpenAI-compatible serving endpoint
DATABRICKS_LLM_ENDPOINT=https://<workspace-host>/serving-endpoints/<endpoint>/invocations
DATABRICKS_TOKEN=dapi...
DATABRICKS_LLM_MODEL=databricks-meta-llama-3-1-70b-instruct

# Alternative OpenAI-compatible endpoint
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_API_KEY=sk-...

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

